    "# Section 3. DCMD module model\n",
    "#\n",
    "# This class performs the actual segment-by-segment DCMD calculation.\n",
    "\n",
    "class DCMDModule:\n",
    "    def __init__(self, p):\n",
    "        self.p = p\n",
    "\n",
    "        # We are converting the empirical mass transfer coefficient from\n",
    "        # kg m^-2 s^-1 K^-1 to kg m^-2 min^-1 K^-1 because the\n",
    "        # model flowrates are carried in kg/min.\n",
    "        self.Km = p.Km_MD * 60.0\n",
    "\n",
    "        # Convert membrane thermal conductivity so the heat terms\n",
    "        # are consistent with the minute-based flowrate calculations in this code.\n",
    "        self.kc = p.kc_MD * 60.0 / 1000.0\n",
    "\n",
    "        # The conductive heat transfer parameters used in the zeta correction\n",
    "        self.U_cond = self.kc / p.delta\n",
    "        self.B = p.cp_v * p.delta / self.kc\n",
    "\n",
    "    def zeta(self, Jm, dT):\n",
    "        # This function calculates the conductive heat transfer correction.\n",
    "        # It returns:\n",
    "        # 1) zF = conductive heat correction on the brine side\n",
    "        # 2) zP = conductive heat correction on the permeate side\n",
    "        #\n",
    "        # However, if there is no positive temperature driving force, the correction is zero.\n",
    "        if dT <= 0:\n",
    "            return 0.0, 0.0\n",
    "\n",
    "        x = self.B * Jm\n",
    "\n",
    "        # The small-x approximation avoids numerical problems,\n",
    "        # so when the flux is very small.\n",
    "        if abs(x) < 1e-6:\n",
    "            ratio_F = 1.0 - x / 2.0 + x**2 / 12.0\n",
    "            ratio_P = 1.0 + x / 2.0 + x**2 / 12.0\n",
    "        else:\n",
    "            ex = np.exp(x)\n",
    "            ratio_F = x / (ex - 1.0)\n",
    "            ratio_P = x * ex / (ex - 1.0)\n",
    "\n",
    "        return self.U_cond * ratio_F * dT, self.U_cond * ratio_P * dT\n",
    "\n",
    "    def solve(self, Q_F0_kgmin, T_F0, w_F0, Q_P0_kgmin, T_P0):\n",
    "        p = self.p\n",
    "        N = p.N_segments\n",
    "        dx = p.L_MD / p.N_segments\n",
    "        dA = p.A_MD / N\n",
    "\n",
    "        # The arrays are defined at the segment nodes,\n",
    "        # it is because there are N segments, there are N+1 node points.\n",
    "        T_F = np.zeros(N + 1)\n",
    "        T_P = np.zeros(N + 1)\n",
    "        Q_F = np.zeros(N + 1)\n",
    "        Q_P = np.zeros(N + 1)\n",
    "        w = np.zeros(N + 1)\n",
    "\n",
    "        # The boundary conditions\n",
    "        T_F[0], Q_F[0], w[0] = T_F0, Q_F0_kgmin, w_F0\n",
    "        T_P[-1], Q_P[-1] = T_P0, Q_P0_kgmin\n",
    "\n",
    "        # The initial guess for the permeate temperature profile\n",
    "        T_P_prev = np.linspace((T_P0 + T_F0) / 2.0, T_P0, N + 1)\n",
    "\n",
    "        total_mass = 0.0\n",
    "        omega = 0.5           # The under-relaxation factor\n",
    "        converged = False\n",
    "\n",
    "        # The outer loop for profile convergence\n",
    "        for iteration in range(300):\n",
    "            # Reset the brine inlet each time\n",
    "            T_F[0], Q_F[0], w[0], total_mass = T_F0, Q_F0_kgmin, w_F0, 0.0\n",
    "\n",
    "            \n",
    "            # Forward sweep on the brine side\n",
    "            # Segment 1 -> Segment N\n",
    "            \n",
    "            for i in range(N):\n",
    "                # The local average permeate temperature used in the flux equation\n",
    "                T_P_cell = 0.5 * (T_P_prev[i] + T_P_prev[i + 1])\n",
    "\n",
    "                # The threshold temperature difference caused by NaCl dissolved in brine\n",
    "                dT_th = NaClProperties.boiling_point_elevation(w[i], T_P_cell)\n",
    "\n",
    "                # The actual local bulk temperature difference\n",
    "                dT = T_F[i] - T_P_cell\n",
    "\n",
    "                # The local mass flux\n",
    "                Jm = self.Km * (dT - dT_th) if dT > dT_th else 0.0\n",
    "\n",
    "                # The water transferred across this one segment\n",
    "                dQ = Jm * dA\n",
    "\n",
    "                # The brine flowrate decreases because water is removed\n",
    "                Q_F[i + 1] = max(Q_F[i] - dQ, 0.01 * Q_F0_kgmin)\n",
    "                dQ = Q_F[i] - Q_F[i + 1]\n",
    "                total_mass += dQ\n",
    "\n",
    "                # But salt remains in the brine, so it becomes more concentrated\n",
    "                w[i + 1] = (w[i] * Q_F[i]) / Q_F[i + 1] if Q_F[i + 1] > 0 else w[i]\n",
    "\n",
    "                # The brine-side energy balance\n",
    "                cp_F = NaClProperties.cp_solution(w[i], T_F[i])\n",
    "                hvap_l = NaClProperties.hvap_solution(w[i], T_F[i])\n",
    "                zF, _ = self.zeta(Jm, max(dT, 0.0))\n",
    "                q_rem = dQ * hvap_l + zF * dA\n",
    "\n",
    "                # The brine cools as heat is removed\n",
    "                T_F[i + 1] = T_F[i] - q_rem / (Q_F[i] * cp_F) if Q_F[i] * cp_F > 0 else T_F[i]\n",
    "\n",
    "                # This helps avoid the brine temperature going below the local permeate temperature\n",
    "                T_F[i + 1] = max(T_F[i + 1], T_P_cell + 0.01)\n",
    "\n",
    "           \n",
    "            # Backward sweep on the permeate side.\n",
    "            # Segment N -> Segment 1\n",
    "            \n",
    "            Q_P[-1], T_P[-1] = Q_P0_kgmin, T_P0\n",
    "\n",
    "            for i in range(N - 1, -1, -1):\n",
    "                T_P_cell = 0.5 * (T_P_prev[i] + T_P_prev[i + 1])\n",
    "                dT_th = NaClProperties.boiling_point_elevation(w[i], T_P_cell)\n",
    "                dT = T_F[i] - T_P_cell\n",
    "                Jm = self.Km * (dT - dT_th) if dT > dT_th else 0.0\n",
    "                dQ = Jm * dA\n",
    "\n",
    "                # The permeate flowrate increases because it receives water from brine in DCMD\n",
    "                Q_P[i] = Q_P[i + 1] + dQ\n",
    "\n",
    "                # The permeate-side energy balance\n",
    "                cp_P = NaClProperties.cp_solution(0, T_P[i + 1])\n",
    "                hvap_l = NaClProperties.hvap(T_P[i + 1])\n",
    "                _, zP = self.zeta(Jm, max(dT, 0.0))\n",
    "                hLp = NaClProperties.hL(0, T_P[i + 1])\n",
    "                q_add = dQ * (hvap_l + hLp) + zP * dA\n",
    "\n",
    "                # The permeate warms up as it receives mass and heat from brine\n",
    "                T_P[i] = (\n",
    "                    (Q_P[i + 1] * cp_P * T_P[i + 1] + q_add) / (Q_P[i] * cp_P)\n",
    "                    if Q_P[i] * cp_P > 0 else T_P[i + 1]\n",
    "                )\n",
    "\n",
    "                # Keeping the permeate below the brine temperature locally\n",
    "                T_P[i] = min(T_P[i], T_F[i] - 0.01)\n",
    "                T_P[i] = max(T_P[i], T_P0)\n",
    "\n",
    "            # Under-relaxation step for stable convergence\n",
    "            T_P_new = omega * T_P + (1.0 - omega) * T_P_prev\n",
    "            dT_P_max = np.max(np.abs(T_P_new - T_P_prev))\n",
    "            T_P_prev = T_P_new\n",
    "\n",
    "            if dT_P_max < 1e-4 and iteration > 2:\n",
    "                converged = True\n",
    "                break\n",
    "\n",
    "        # Calculating the average flux for the whole module\n",
    "        avg_flux = (total_mass / p.A_MD) / 60.0\n",
    "\n",
    "        \n",
    "        # Building a transparent segment-by-segment results table after running this code\n",
    "        \n",
    "        segment_rows = []\n",
    "        for i in range(N):\n",
    "            T_P_cell = 0.5 * (T_P[i] + T_P[i + 1])\n",
    "            dT_th = NaClProperties.boiling_point_elevation(w[i], T_P_cell)\n",
    "            dT = T_F[i] - T_P_cell\n",
    "            Jm = self.Km * (dT - dT_th) if dT > dT_th else 0.0\n",
    "            dQ = Jm * dA\n",
    "\n",
    "            segment_rows.append({\n",
    "                \"segment\": i + 1,\n",
    "                \"x_in_m\": i * dx,\n",
    "                \"x_out_m\": (i + 1) * dx,\n",
    "                \"x_mid_m\": (i + 0.5) * dx,\n",
    "\n",
    "                # The brine-side temperatures\n",
    "                \"T_F_in_C\": T_F[i],\n",
    "                \"T_F_out_C\": T_F[i + 1],\n",
    "\n",
    "                # The permeate-side temperatures\n",
    "                # For the permeate, \"in\" and \"out\" are written relative to the local segment\n",
    "                \"T_P_in_C\": T_P[i + 1],\n",
    "                \"T_P_out_C\": T_P[i],\n",
    "                \"T_P_cell_avg_C\": T_P_cell,\n",
    "\n",
    "                # The brine flowrate and concentration\n",
    "                \"Q_F_in_kg_h\": Q_F[i] * 60.0,\n",
    "                \"Q_F_out_kg_h\": Q_F[i + 1] * 60.0,\n",
    "                \"w_F_in_wt_pct\": w[i] * 100.0,\n",
    "                \"w_F_out_wt_pct\": w[i + 1] * 100.0,\n",
    "\n",
    "                # The permeate flowrate\n",
    "                \"Q_P_in_kg_h\": Q_P[i + 1] * 60.0,\n",
    "                \"Q_P_out_kg_h\": Q_P[i] * 60.0,\n",
    "\n",
    "                # The segment temperature driving force and flux terms\n",
    "                \"dT_C\": dT,\n",
    "                \"dT_th_C\": dT_th,\n",
    "                \"Jm_kg_m2_min\": Jm,\n",
    "                \"Jm_kg_m2_h\": Jm * 60.0,\n",
    "\n",
    "                # The water transferred across this one segment\n",
    "                \"dQ_kg_h\": dQ * 60.0,\n",
    "            })\n",
