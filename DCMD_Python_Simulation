    "from dataclasses import dataclass\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from IPython.display import display, Markdown\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class StreamInputs:\n",
    "    # The feed concentration from RO expressed as NaCl wt%\n",
    "    w_NaCl_wt_pct: float = 3.67\n",
    "\n",
    "    # Feed brine density from RO in kg/m^3 (obtained using Sharqawry et al (2010) eq.8 for density at 25oC and 0.0367 kg/kg (3.67wt%))\n",
    "    rho_brine_kgm3: float = 1024.1566\n",
    "\n",
    "    # Volumetric flowrate of brine from RO in l/h\n",
    "    Q_vol_Lh: float = 218.7\n",
    "\n",
    "    # Feed temperature entering the wider monovalent section.\n",
    "    # Note that the DCMD module itself is fed at T_H after heating.\n",
    "    T_feed: float = 25.0\n",
    "\n",
    "    # Molecular weight of NaCl in g/mol\n",
    "    M_NaCl_gmol: float = 58.44\n",
    "\n",
    "    @property\n",
    "    def Q_brine_total(self):\n",
    "        # This converts the volumetric feed flowrate to total mass flowrate\n",
    "        return self.Q_vol_Lh * self.rho_brine_kgm3 / 1000.0\n",
    "\n",
    "    def feed_composition(self):\n",
    "        # This converts wt% into mass flowrate of NaCl and water\n",
    "        # and also calculates molality, which is then used in the\n",
    "        # DeltaT_th formula.\n",
    "        w_NaCl = self.w_NaCl_wt_pct / 100.0\n",
    "        mass_NaCl_kgh = w_NaCl * self.Q_brine_total\n",
    "        water_kgh = self.Q_brine_total - mass_NaCl_kgh\n",
    "        molality = (mass_NaCl_kgh / self.M_NaCl_gmol * 1e3) / water_kgh\n",
    "        return {\n",
    "            'w_NaCl': w_NaCl,\n",
    "            'mass_NaCl_kgh': mass_NaCl_kgh,\n",
    "            'water_kgh': water_kgh,\n",
