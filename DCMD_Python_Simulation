    "# Section 2: The property correlations\n",
    "#\n",
    "# This section stores the simplified property functions for\n",
    "# NaCl-water brine and pure water. They're used inside\n",
    "# each segment calculation.\n",
    "\n",
    "class NaClProperties:\n",
    "    M_NaCl = 58.44e-3\n",
    "    cp_NaCl = 0.89\n",
    "\n",
    "    @staticmethod\n",
    "    def molality_from_w(w):\n",
    "        # Converts NaCl mass fraction to molality in mol/kg water\n",
    "        return 1e6 if w >= 1.0 else w / (NaClProperties.M_NaCl * (1.0 - w))\n",
    "\n",
    "    @staticmethod\n",
    "    def density(w, T=25.0):\n",
    "        # Approximate density correlation used in the V2 design\n",
    "        return (\n",
    "            9.999e2 + 2.034e-2*T - 6.162e-3*T**2 + 2.261e-5*T**3 - 4.657e-8*T**4\n",
    "            + 8.020e2*w - 2.001*w*T + 1.677e-2*w*T**2 - 3.060e-5*w**2*T - 1.613e-5*w**2\n",
    "        )\n",
    "\n",
    "    @staticmethod\n",
    "    def cp_water(_=25.0):\n",
    "        # Specific heat capacity of water (at liquid state, the cp of water changes marginally, so it \n",
    "        return 4.18\n",
    "\n",
    "    @staticmethod\n",
    "    def cp_solution(w, T=25.0):\n",
    "        # Calculating the brine heat capacity (equation A11 from Lin et al., (2014))\n",
    "        return (1.0 - w) * NaClProperties.cp_water(T) + w * NaClProperties.cp_NaCl\n",
    "\n",
    "    @staticmethod\n",
    "    def boiling_point_elevation(w, T_P):\n",
    "        # This gives the threshold temperature difference term.\n",
    "        # It comes from the Lin-style fitted relation used in the report.\n",
    "        C = min(NaClProperties.molality_from_w(w), 6.5)\n",
    "        m_coeff = 2.689e-4 * C**2 + 4.428e-3 * C + 8.847e-5\n",
    "        n_coeff = 3.024e-2 * C**2 + 4.015e-1 * C + 2.032e-2\n",
    "        return max(m_coeff * T_P + n_coeff, 0.0)\n",
    "\n",
    "    @staticmethod\n",
    "    def hvap(T):\n",
    "        # This calculates the latent heat of vaporisation in kJ/kg as a function of temperature\n",
    "        h_Jkg = 2.501e6 - 2.369e3*T + 2.678e-1*T**2 - 8.103e-3*T**3 - 2.079e-5*T**4\n",
    "        return h_Jkg / 1000.0\n",
    "\n",
    "    @staticmethod\n",
    "    def hvap_solution(_, T):\n",
    "        # In this model the brine latent heat is simply taken to be the same as water\n",
    "        return NaClProperties.hvap(T)\n",
    "\n",
    "    @staticmethod\n",
    "    def hL(w, T, T_ref=0.0, n_steps=5):\n",
    "        # The liquid enthalpy is obtained by integrating cp from a reference temperature\n",
    "        if abs(T - T_ref) < 1e-10:\n",
    "            return 0.0\n",
    "        dT = (T - T_ref) / n_steps\n",
    "        cp_vals = [NaClProperties.cp_solution(w, T_ref + i * dT) for i in range(n_steps + 1)]\n",
    "        return dT * (0.5 * cp_vals[0] + sum(cp_vals[1:-1]) + 0.5 * cp_vals[-1])"
   ]
