    "# Section 4: System wrapper & main outputs\n",
    "\n",
    "\n",
    "class MDSinglePass:\n",
    "    def __init__(self, stream, design):\n",
    "        self.stream = stream\n",
    "        self.design = design\n",
    "\n",
    "        # Making sure the NaCl heat capacity used in the property class\n",
    "        # matches the chosen design assumptions\n",
    "        NaClProperties.cp_NaCl = design.cp_NaCl\n",
    "\n",
    "        self.md = DCMDModule(design)\n",
    "\n",
    "    def run(self, verbose=True):\n",
    "        s, d = self.stream, self.design\n",
    "        feed = s.feed_composition()\n",
    "\n",
    "        # The feed basis for the DCMD module\n",
    "        w_F = feed['w_NaCl']\n",
    "        Q_F_kgmin = s.Q_brine_total / 60.0\n",
    "\n",
    "        # The permeate recirculation basis set by alpha (alpha=1 by default)\n",
    "        Q_P_kgmin = d.alpha * Q_F_kgmin\n",
    "\n",
    "        # Running the MD module\n",
    "        md = self.md.solve(Q_F_kgmin, d.T_H, w_F, Q_P_kgmin, d.T_C)\n",
    "\n",
    "        # Converting the final brine stream into engineering outputs\n",
    "        Q_brine_out_kgh = md['Q_F_out_kgmin'] * 60.0\n",
    "        T_brine_out = md['T_F_out']\n",
    "        w_brine_out = md['w_F_out']\n",
    "        vol_out_Lh = Q_brine_out_kgh / NaClProperties.density(w_brine_out, T_brine_out) * 1000.0\n",
    "        recovery = md['distillate_kgh'] / feed['water_kgh'] * 100.0\n",
    "\n",
    "        results = {\n",
    "            'Q_feed_kgh': s.Q_brine_total,\n",
    "            'vol_feed_Lh': s.Q_vol_Lh,\n",
    "            'w_feed': w_F,\n",
    "            'Q_brine_out_kgh': Q_brine_out_kgh,\n",
    "            'vol_brine_out_Lh': vol_out_Lh,\n",
    "            'w_brine_out': w_brine_out,\n",
    "            'w_brine_out_percent': w_brine_out * 100.0,\n",
    "            'T_brine_out': T_brine_out,\n",
    "            'Q_distillate_kgh': md['distillate_kgh'],\n",
    "            'T_perm_out_MD': md['T_P_out'],\n",
    "            'water_recovery_pct': recovery,\n",
    "            'avg_flux_kgm2s': md['avg_flux_kgm2s'],\n",
    "            'avg_flux_kgm2h': md['avg_flux_kgm2h'],\n",
    "            'md_result': md,\n",
    "        }\n",
    "\n",
    "        if verbose:\n",
    "            print('=' * 70)\n",
    "            print('MD-ONLY SINGLE-PASS STEADY-STATE SIMULATION')\n",
    "            print('=' * 70)\n",
    "            print(f\"Brine feed:  {results['Q_feed_kgh']:.2f} kg/h  ({results['vol_feed_Lh']:.1f} L/h)\")\n",
    "            print(f\"NaCl in feed: {w_F*100:.3f} wt%\")\n",
    "            print(f\"MD inputs:    T_H = {d.T_H:.1f} C, T_C = {d.T_C:.1f} C, A = {d.A_MD:.1f} m2\")\n",
    "            print(f\"Km:           {d.Km_MD:.2e} kg/(m2 s K), alpha = {d.alpha:.2f}\")\n",
    "            print(f\"Iterations:   {md['iterations']}  ({'converged' if md['converged'] else 'NOT CONVERGED'})\")\n",
    "            print('-' * 70)\n",
    "            print(f\"Brine outlet: {Q_brine_out_kgh:.2f} kg/h  ({vol_out_Lh:.1f} L/h)\")\n",
    "            print(f\"             {w_brine_out*100:.3f} wt% NaCl  {T_brine_out:.1f} C\")\n",
    "            print(f\"Distillate:   {md['distillate_kgh']:.3f} kg/h\")\n",
    "            print(f\"Permeate out: {md['T_P_out']:.1f} C\")\n",
    "            print(f\"Avg flux:     {md['avg_flux_kgm2h']:.4f} kg/(m2 h)\")\n",
    "            print(f\"Recovery:     {recovery:.2f}% per pass\")\n",
    "            print('=' * 70)\n",
    "\n",
    "        return results\n",
    "\n",
    "\n",
    "\n",
    "# Section 5: Running the model\n",
    "\n",
    "\n",
    "stream = StreamInputs()\n",
    "design = DesignParameters()\n",
    "system = MDSinglePass(stream, design)\n",
    "results = system.run(verbose=True)\n",
